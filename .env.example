# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

GROQ_API_KEY=MY_GROQ_API_KEY
ZAI_API_KEY=MY_ZAI_API_KEY
OPENROUTER_API_KEY=MY_OPENROUTER_API_KEY
OPENAI_API_KEY=MY_OPENAI_API_KEY
HUGGINGFACE_API_KEY=MY_HUGGINGFACE_API_KEY
DEEPSEEK_API_KEY=MY_DEEPSEEK_API_KEY
OLLAMA_API_URL=http://localhost:11434

# Firebase configuration variables
# NOTE: These values must be copied from the Android app entry in the Firebase Console
# under Project Settings > Your apps (under com.lyo.fooddelivery), NOT from any Web app entry
# (such as Edappadi Kadai or other leftover Web configurations).
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_DATABASE_URL=YOUR_FIREBASE_DATABASE_URL
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
