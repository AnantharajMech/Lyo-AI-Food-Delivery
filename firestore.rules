rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isAdmin() {
      return hasAnyRole(['ADMIN']);
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || hasAnyRole(['ADMIN', 'RIDER']));
      allow list: if isAdmin();
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();

      match /sessions/{sessionId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      match /deviceTokens/{tokenId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- Admins ---
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // --- Vendors ---
    match /vendors/{vendorId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- Menu Items ---
    match /menu_items/{itemId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- Promo Banners ---
    match /promo_banners/{bannerId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- App Settings ---
    match /app_settings/{settingId} {
      allow read: if true; // Read allowed for all
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /ek_orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasAnyRole(['ADMIN', 'RIDER']));
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasAnyRole(['ADMIN', 'RIDER']));
      allow delete: if isAdmin();
    }

    // --- Delivery Rides ---
    match /delivery_rides/{rideId} {
      allow read: if isAuthenticated() && (
        hasAnyRole(['ADMIN', 'RIDER']) ||
        (exists(/databases/$(database)/documents/ek_orders/$(string(resource.data.orderId))) &&
         get(/databases/$(database)/documents/ek_orders/$(string(resource.data.orderId))).data.userId == request.auth.uid)
      );
      allow write: if isAuthenticated() && hasAnyRole(['ADMIN', 'RIDER']);
    }

    // --- Order Messages (Chat) ---
    match /order_messages/{orderId} {
      function canAccessOrderChat() {
        return isAuthenticated() && (
          hasAnyRole(['ADMIN']) ||
          (exists(/databases/$(database)/documents/ek_orders/$(orderId)) && (
            get(/databases/$(database)/documents/ek_orders/$(orderId)).data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/ek_orders/$(orderId)).data.riderUid == request.auth.uid ||
            hasAnyRole(['RIDER'])
          ))
        );
      }
      allow read, write: if canAccessOrderChat();
      
      match /messages/{messageId} {
        allow read, write: if canAccessOrderChat();
      }
    }

    // --- Idempotency Keys ---
    match /idempotency_keys/{keyId} {
      allow read, write: if isAuthenticated();
    }
  }
}

