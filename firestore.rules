rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isAdmin() {
      return isAuthenticated() && (
             request.auth.token.admin == true ||
             request.auth.token.role == 'ADMIN' ||
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
             hasAnyRole(['ADMIN', 'ADMINISTRATOR', 'admin'])
      );
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']));
      allow list: if isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) &&
                    (request.resource.data.role != 'ADMIN' || isAdmin());
      allow update: if isAuthenticated() && request.auth.uid == userId &&
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /sessions/{sessionId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      match /deviceTokens/{tokenId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
      match /saved_addresses/{addressId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    // --- Admins ---
    match /admins/{adminUid} {
      allow read: if isAuthenticated() && (request.auth.uid == adminUid || isAdmin());
      allow write, delete: if isAuthenticated();
    }

    // --- Riders ---
    match /riders/{riderId} {
      allow read: if isAuthenticated();
      allow write, delete: if isAdmin();
    }

    // --- Vendors ---
    match /vendors/{vendorId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write, delete: if isAdmin();
      }
    }

    // --- Stores ---
    match /stores/{storeId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write, delete: if isAdmin();
      }
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- Menu Items ---
    match /menu_items/{itemId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- Promo Banners ---
    match /promo_banners/{bannerId} {
      allow read: if true; // Guest catalog view allowed
      allow write, delete: if isAdmin();
    }

    // --- App Settings ---
    match /app_settings/{settingId} {
      allow read: if true; // Read allowed for all
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /ek_orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']));
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.total is number && request.resource.data.total > 0 &&
                    request.resource.data.itemsTotal is number && request.resource.data.itemsTotal > 0 &&
                    request.resource.data.deliveryFee is number && request.resource.data.deliveryFee > 0 &&
                    request.resource.data.status == 'PENDING' &&
                    request.resource.data.paymentStatus == 'UNPAID';
      allow update: if isAuthenticated() && (
                    hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']) ||
                    (resource.data.userId == request.auth.uid &&
                     !request.resource.data.diff(resource.data).affectedKeys().hasAny(['total', 'itemsTotal', 'deliveryFee', 'status', 'paymentStatus']))
                    );
      allow delete: if isAdmin();
    }

    // --- Delivery Rides ---
    match /delivery_rides/{rideId} {
      allow read: if isAuthenticated() && (
        hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']) ||
        (exists(/databases/$(database)/documents/ek_orders/$(string(resource.data.orderId))) &&
         get(/databases/$(database)/documents/ek_orders/$(string(resource.data.orderId))).data.userId == request.auth.uid)
      );
      allow write: if isAuthenticated() && hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']);
    }

    // --- Order Messages (Chat) ---
    match /order_messages/{orderId} {
      function canAccessOrderChat() {
        return isAuthenticated() && (
          hasAnyRole(['ADMIN']) ||
          (exists(/databases/$(database)/documents/ek_orders/$(orderId)) && (
            get(/databases/$(database)/documents/ek_orders/$(orderId)).data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/ek_orders/$(orderId)).data.riderUid == request.auth.uid ||
            hasAnyRole(['RIDER', 'DELIVERY'])
          ))
        );
      }
      allow read, write: if canAccessOrderChat();
      
      match /messages/{messageId} {
        allow read, write: if canAccessOrderChat();
      }
    }

    // --- Support Tickets ---
    match /support_tickets/{ticketId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- Menu Backups ---
    match /menu_backups/{backupId} {
      allow read, write: if isAdmin();
    }

    // --- Bulk Import Logs ---
    match /bulk_import_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // --- Idempotency Keys ---
    match /idempotency_keys/{keyId} {
      allow read, write: if isAuthenticated();
    }

    // --- Coupons ---
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Offers ---
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // --- Location Updates ---
    match /location_updates/{updateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']) || request.auth.uid == updateId);
    }

    // --- Tracking Logs ---
    match /tracking_logs/{logId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']));
      allow write: if isAuthenticated() && (hasAnyRole(['ADMIN', 'RIDER', 'DELIVERY']) || request.resource.data.userId == request.auth.uid);
    }

    // --- Loyalty ---
    match /loyalty/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // --- AI Recommendations ---
    match /ai_recommendations/{recId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /recommendations/{recId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // --- Saved Addresses (Top-level fallback) ---
    match /saved_addresses/{addressId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
